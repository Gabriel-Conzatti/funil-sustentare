# ==============================================================
# Funil Sustentare — variáveis de ambiente
# Copie para .env e ajuste os valores.
# ==============================================================

# Banco de dados
# DEV (local, rápido, sem servidor): SQLite
DATABASE_URL="file:./dev.db"

# PRODUÇÃO (Hostinger VPS — MySQL):
# NÃO precisa trocar o schema à mão — os scripts *:prod geram o schema MySQL.
# Basta apontar a DATABASE_URL para o MySQL:
# DATABASE_URL="mysql://u278435480_FunilADM:SUA_SENHA@localhost:3306/u278435480_Funil"
#   - localhost  -> MySQL no mesmo VPS (recomendado)
#   - host remoto -> exige habilitar "Remote MySQL" e liberar o IP do VPS

# Segredos JWT (troque por valores fortes e aleatórios em produção)
JWT_ACCESS_SECRET="troque-este-access-secret-por-um-valor-aleatorio-forte"
JWT_REFRESH_SECRET="troque-este-refresh-secret-por-um-valor-aleatorio-forte"

# Expiração dos tokens
ACCESS_TOKEN_TTL="8h"
REFRESH_TOKEN_TTL="7d"

# Credenciais do administrador inicial (usadas no seed)
ADMIN_EMAIL="admin@sustentare.com"
ADMIN_PASSWORD="Admin@123"
ADMIN_USERNAME="admin"
