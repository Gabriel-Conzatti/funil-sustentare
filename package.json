{
  "name": "funil-sustentare",
  "version": "1.0.0",
  "private": true,
  "description": "Funil Sustentare — CRM comercial configurável (funis, clientes, mensagens, auditoria)",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "setup": "prisma db push && npm run db:seed",
    "schema:mysql": "node scripts/gen-mysql-schema.mjs",
    "generate:prod": "npm run schema:mysql && prisma generate --schema prisma/schema.prod.prisma",
    "db:push:prod": "npm run schema:mysql && prisma db push --schema prisma/schema.prod.prisma",
    "db:seed:prod": "tsx prisma/seed.ts",
    "setup:prod": "npm run db:push:prod && npm run db:seed:prod",
    "build:prod": "npm run generate:prod && next build",
    "start:prod": "next start -p 3000"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^17.0.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "eslint-config-next": "^14.2.35",
    "jose": "^5.9.6",
    "lucide-react": "^0.454.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
