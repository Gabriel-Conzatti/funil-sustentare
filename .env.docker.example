# ==============================================================
# Deploy com Docker — copie para ".env" na VPS e ajuste os valores.
#   cp .env.docker.example .env && nano .env
# Gere segredos fortes com:  openssl rand -base64 48
# ==============================================================

# Senhas do banco (MySQL roda em container, dentro da VPS)
DB_PASSWORD=troque_por_uma_senha_forte
DB_ROOT_PASSWORD=troque_por_outra_senha_forte

# Segredos JWT (troque por valores aleatórios e longos)
JWT_ACCESS_SECRET=troque_use_openssl_rand_base64_48
JWT_REFRESH_SECRET=troque_outro_openssl_rand_base64_48

# Administrador inicial do sistema (login)
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=troque_a_senha_do_admin
ADMIN_USERNAME=admin
